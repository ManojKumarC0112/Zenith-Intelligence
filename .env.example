# ─────────────────────────────────────────────────────────────
# FocusOS / Smart Task & Automation API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Django core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=True

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Local LLM (Ollama)
LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434/api/generate
LOCAL_LLM_MODEL=mistral
LOCAL_LLM_TIMEOUT_SECONDS=120

# Privacy gate: set to 1 to keep ALL learning & inference on-device
LOCAL_ONLY_TRAINING=1

# Celery / Redis broker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Sentence-Transformers model name (used in phase2 embeddings)
# Falls back to fast hash-embedding if model is unavailable.
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
